# MongoDB Atlas connection string (required)
# Atlas: Connect → Drivers → Node.js → copy the SRV URI, then URL-encode user/password.
# Example: mongodb+srv://user:pass@cluster0.abcde.mongodb.net/coursebox_prototype?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=coursebox_prototype

# Optional shared secret for Zapier webhook requests via x-zapier-secret header
ZAPIER_WEBHOOK_SECRET=local-zapier-secret

# Fallback direct launch URL when full LTI is not configured.
# Final URL is built as `${COURSEBOX_EMBED_BASE_URL}/${course.externalId}`.
COURSEBOX_EMBED_BASE_URL=https://example.coursebox.ai/course

# ---- LTI 1.3 (platform side) ----
# Public URL of this app. In Vercel set this to your custom domain (https://your-domain.com).
LTI_PLATFORM_ISSUER=
# Client ID you choose to identify this platform; same value goes in the Coursebox registration form.
LTI_TOOL_CLIENT_ID=
# Deployment ID assigned by Coursebox after registration.
LTI_DEPLOYMENT_ID=
# Coursebox launch URL (the "Launch URL" Coursebox provides).
LTI_TARGET_LINK_URI=
# Coursebox redirect URI for the form-post id_token (typically same host as LTI_TARGET_LINK_URI).
COURSEBOX_LTI_LAUNCH_URL=
# Coursebox OIDC initiate-login URL (Coursebox provides this in their integration docs).
COURSEBOX_LTI_INITIATE_LOGIN_URL=
# kid that matches a key in LTI_PLATFORM_PUBLIC_JWKS.
LTI_KEY_ID=

# RS256 private key, PKCS8 PEM. On Vercel paste the full multiline PEM into the Env Var UI.
# For local .env.local use \n escapes on a single line.
LTI_PLATFORM_PRIVATE_KEY_PEM=

# Public JWKS as a JSON string. Served at /api/.well-known/jwks.json for Coursebox to fetch.
LTI_PLATFORM_PUBLIC_JWKS={"keys":[]}
